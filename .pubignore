# ============================================================
# Zenify .pubignore
#
# Controls what is excluded from the pub.dev package upload.
# pub.dev rewards: README, CHANGELOG, LICENSE, lib/, example/
# Everything else should be excluded to keep the package lean.
# ============================================================

# ---- Build artifacts & tooling caches ----------------------
build/
coverage/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
.metadata

# ---- Documentation (linked from README as absolute GitHub URLs) ------------
# docs render beautifully on GitHub; no need to ship them in the package.
doc/
.idea/
.DS_Store
*.iml

# ---- Internal strategy & working documents -----------------
ARCHITECTURAL_REVIEW_2025.md
STRATEGIC_ROADMAP_2026.md
ROADMAP.md
CLAUDE.md
BUILDER_ARCHITECTURE.md
CACHE_CLEARED.md
COMMUNITY_RESPONSE.md
COMMUNITY_RESPONSE_CONTROLLERS.md
DEVTOOLS_FIX.md
DEVTOOLS_STATUS.md
DEVTOOLS_TESTING.md
DOCUMENTATION_IMPROVEMENTS.md
DOCUMENTATION_REVIEW.md
DOCUMENTATION_UPDATE_SUMMARY.md
FEATURE_IMPLEMENTATION_SUMMARY.md
GITHUB_ISSUE_RESPONSE.md
HIERARCHICAL_DI_COMPARISON.md
INSPECTOR_REVIEW.md
MIGRATION_DEVTOOLS.md
QUERY_ARCHITECTURE_REVIEW.md
README_REVIEW.md
STRATEGIC_ROADMAP_2025.md
V1_5_0_COMPLETE.md
V1_5_0_IMPLEMENTATION_SUMMARY.md
V1_5_0_MIGRATION_PLAN.md

# ---- Test suite (not useful to consumers) ------------------
# Tests inflate the download significantly (2000+ files).
# Users can run tests from the GitHub source if needed.
test/
flutter_test_config.dart

# ---- Developer tooling (useful on GitHub, not pub.dev) -----
tool/
.github/
.agentdocs/
.claude/

# ---- Example sub-apps (full Flutter apps — link from GitHub, not pub.dev) --
# pub.dev only needs example/main.dart + example/pubspec.yaml for the score.
# The sub-apps are large, self-contained projects better accessed on GitHub.
example/counter/
example/todo/
example/ecommerce/
example/hierarchical_scopes/
example/zen_query/
example/zen_offline/
example/zenify_showcase/
example/lib/
example/exception_demo.dart

# ---- Exclude noise from the top-level example folder -------
example/.dart_tool/
example/.idea/
example/.DS_Store
example/*.iml
example/pubspec.lock
example/devtools_options.yaml

# ---- Internal planning docs (not user-facing) --------------
# Note: doc/ guides ARE kept — they're linked from the README and
# resolve correctly on both GitHub and pub.dev.
doc/PROJECT_EVALUATION.md

